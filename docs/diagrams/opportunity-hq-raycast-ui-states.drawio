<mxfile host="app.diagrams.net" modified="2026-06-24T00:00:00.000Z" agent="Codex" version="24.7.17" type="device">
  <diagram id="opportunity-hq-raycast-ui-states" name="Raycast UI States">
    <mxGraphModel dx="1800" dy="1400" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1800" pageHeight="1400" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <mxCell id="title" value="Opportunity HQ Raycast UI States" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontFamily=Helvetica;fontSize=34;fontStyle=1;fontColor=#111827;" vertex="1" parent="1">
          <mxGeometry x="390" y="30" width="1020" height="52" as="geometry"/>
        </mxCell>
        <mxCell id="subtitle" value="Natural-language sketch. Not implementation. Six current commands stay visible. Codex Assist is a secondary review path." style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontFamily=Helvetica;fontSize=17;fontColor=#475569;" vertex="1" parent="1">
          <mxGeometry x="300" y="84" width="1200" height="34" as="geometry"/>
        </mxCell>

        <mxCell id="truth" value="Durable truth: Opportunity HQ&#xa;&#xa;Projects: Paid by July 1, Blue collar resume ready, White collar video/broadcast applications, Upwork consultation / proposals, Singleton proof + website&#xa;&#xa;Task state fields: Bucket, Status, Money Priority, Goal Horizon, Work Date, Shift, Duration, Link, Portfolio Note, Notes" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;fillColor=#F5F3FF;strokeColor=#6D28D9;strokeWidth=3;fontFamily=Helvetica;fontSize=16;fontColor=#2E1065;spacing=14;" vertex="1" parent="1">
          <mxGeometry x="70" y="145" width="1660" height="120" as="geometry"/>
        </mxCell>

        <mxCell id="log" value="Log Task&#xa;&#xa;Raycast UI state: Form&#xa;Use when: one thing is real enough to save&#xa;&#xa;Fields shown: Task, Bucket, Duration, Project, Link, Notes&#xa;&#xa;ActionPanel: Log Task, maybe Codex Assist later for suggested fields" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;fillColor=#EFF6FF;strokeColor=#2563EB;strokeWidth=3;fontFamily=Helvetica;fontSize=15;fontColor=#1E3A8A;spacing=12;" vertex="1" parent="1">
          <mxGeometry x="70" y="320" width="340" height="190" as="geometry"/>
        </mxCell>
        <mxCell id="log-notes" value="Notes / Canva edits&#xa;&#xa;&#xa;&#xa;" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;fillColor=#FFFFFF;strokeColor=#CBD5E1;strokeWidth=2;dashed=1;fontFamily=Helvetica;fontSize=15;fontColor=#64748B;spacing=12;" vertex="1" parent="1">
          <mxGeometry x="430" y="320" width="220" height="190" as="geometry"/>
        </mxCell>

        <mxCell id="update" value="Update Task&#xa;&#xa;Raycast UI state: List of tasks -&gt; Edit Form&#xa;Use when: task already exists&#xa;&#xa;Fields changed: Status, Bucket, Duration, Money Priority, Project, Work Date, Shift, Link, Portfolio Note, Notes&#xa;&#xa;ActionPanel: Edit, Set Today, Start, Waiting, Done, Park, Open links" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;fillColor=#EFF6FF;strokeColor=#2563EB;strokeWidth=3;fontFamily=Helvetica;fontSize=15;fontColor=#1E3A8A;spacing=12;" vertex="1" parent="1">
          <mxGeometry x="690" y="320" width="390" height="190" as="geometry"/>
        </mxCell>
        <mxCell id="update-notes" value="Notes / Canva edits&#xa;&#xa;&#xa;&#xa;" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;fillColor=#FFFFFF;strokeColor=#CBD5E1;strokeWidth=2;dashed=1;fontFamily=Helvetica;fontSize=15;fontColor=#64748B;spacing=12;" vertex="1" parent="1">
          <mxGeometry x="1100" y="320" width="220" height="190" as="geometry"/>
        </mxCell>

        <mxCell id="plan" value="Plan Today&#xa;&#xa;Raycast UI state: List now, possible Grid/Kanban later&#xa;Use when: deciding what actually gets a block today&#xa;&#xa;Natural view: lanes by Bucket or urgency&#xa;Critical first, Strategic second, Parked stays out&#xa;&#xa;ActionPanel: Assign Shift, Start, Open in Notion" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;fillColor=#FFFBEB;strokeColor=#D97706;strokeWidth=3;fontFamily=Helvetica;fontSize=15;fontColor=#78350F;spacing=12;" vertex="1" parent="1">
          <mxGeometry x="70" y="560" width="390" height="210" as="geometry"/>
        </mxCell>
        <mxCell id="plan-notes" value="Notes / Canva edits&#xa;&#xa;Kanban idea: Bucket lanes?&#xa;Urgency lanes?&#xa;Both?" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;fillColor=#FFFFFF;strokeColor=#CBD5E1;strokeWidth=2;dashed=1;fontFamily=Helvetica;fontSize=15;fontColor=#64748B;spacing=12;" vertex="1" parent="1">
          <mxGeometry x="480" y="560" width="230" height="210" as="geometry"/>
        </mxCell>

        <mxCell id="start" value="Start Application&#xa;&#xa;Raycast UI state: List of Cash Jobs / Career Jobs / Upwork tasks&#xa;Use when: about to work the application/proposal&#xa;&#xa;Shows: task, status, bucket, time&#xa;Does: open job/proposal link, open resume path, mark In Motion&#xa;&#xa;ActionPanel: Start, Open Link, Open Resume, Open in Notion" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;fillColor=#ECFDF5;strokeColor=#059669;strokeWidth=3;fontFamily=Helvetica;fontSize=15;fontColor=#064E3B;spacing=12;" vertex="1" parent="1">
          <mxGeometry x="750" y="560" width="390" height="210" as="geometry"/>
        </mxCell>
        <mxCell id="start-notes" value="Notes / Canva edits&#xa;&#xa;&#xa;&#xa;" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;fillColor=#FFFFFF;strokeColor=#CBD5E1;strokeWidth=2;dashed=1;fontFamily=Helvetica;fontSize=15;fontColor=#64748B;spacing=12;" vertex="1" parent="1">
          <mxGeometry x="1160" y="560" width="230" height="210" as="geometry"/>
        </mxCell>

        <mxCell id="draft" value="Draft Proposal&#xa;&#xa;Raycast UI state: Upwork task list -&gt; draft detail&#xa;Use when: copied Upwork post needs a concise proposal&#xa;&#xa;Shows: generated draft, task context, original link&#xa;Does: copy draft, append note, mark Waiting after user chooses&#xa;&#xa;ActionPanel: Copy Draft, Log Draft, Open Link, Open in Notion" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;fillColor=#F0FDF4;strokeColor=#16A34A;strokeWidth=3;fontFamily=Helvetica;fontSize=15;fontColor=#14532D;spacing=12;" vertex="1" parent="1">
          <mxGeometry x="70" y="820" width="390" height="220" as="geometry"/>
        </mxCell>
        <mxCell id="draft-notes" value="Notes / Canva edits&#xa;&#xa;&#xa;&#xa;" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;fillColor=#FFFFFF;strokeColor=#CBD5E1;strokeWidth=2;dashed=1;fontFamily=Helvetica;fontSize=15;fontColor=#64748B;spacing=12;" vertex="1" parent="1">
          <mxGeometry x="480" y="820" width="230" height="220" as="geometry"/>
        </mxCell>

        <mxCell id="proof" value="Capture Portfolio&#xa;&#xa;Raycast UI state: Form with file/folder/task choices&#xa;Use when: proof exists and should attach back to work&#xa;&#xa;Shows: selected file, Eagle folder, tags, related Portfolio task&#xa;Does: import to Eagle, attach proof link/note, complete proof task&#xa;&#xa;ActionPanel: Capture Portfolio, Open Portfolio Folder" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;fillColor=#F0FDF4;strokeColor=#16A34A;strokeWidth=3;fontFamily=Helvetica;fontSize=15;fontColor=#14532D;spacing=12;" vertex="1" parent="1">
          <mxGeometry x="750" y="820" width="390" height="220" as="geometry"/>
        </mxCell>
        <mxCell id="proof-notes" value="Notes / Canva edits&#xa;&#xa;&#xa;&#xa;" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;fillColor=#FFFFFF;strokeColor=#CBD5E1;strokeWidth=2;dashed=1;fontFamily=Helvetica;fontSize=15;fontColor=#64748B;spacing=12;" vertex="1" parent="1">
          <mxGeometry x="1160" y="820" width="230" height="220" as="geometry"/>
        </mxCell>

        <mxCell id="codex" value="Codex Assist&#xa;&#xa;Not a first-class command here. Secondary review path.&#xa;&#xa;Use when text needs reasoning: suggested fields, cleaned notes, proposal angle, resume angle, split-task suggestion, proof-to-copy draft.&#xa;&#xa;Rule: review before write/send. Native Raycast action first." style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;fillColor=#FEF3C7;strokeColor=#D97706;strokeWidth=3;fontFamily=Helvetica;fontSize=16;fontStyle=1;fontColor=#78350F;spacing=14;" vertex="1" parent="1">
          <mxGeometry x="1430" y="320" width="300" height="250" as="geometry"/>
        </mxCell>

        <mxCell id="goal" value="Goal Check-In / planning state&#xa;&#xa;Not a new database. Use it to decide which existing task/project state should change.&#xa;&#xa;Natural output: Today, This Week, Strategic, Blocked.&#xa;&#xa;Durable only when it becomes an Opportunity Task or Project update." style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;fillColor=#F8FAFC;strokeColor=#111827;strokeWidth=3;fontFamily=Helvetica;fontSize=16;fontColor=#111827;spacing=14;" vertex="1" parent="1">
          <mxGeometry x="1430" y="620" width="300" height="250" as="geometry"/>
        </mxCell>

        <mxCell id="rule" value="Working rule: Raycast shows the action state. Opportunity HQ owns durable truth. Codex helps only when wording or routing needs thought." style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;fillColor=#F8FAFC;strokeColor=#111827;strokeWidth=2;fontFamily=Helvetica;fontSize=20;fontStyle=1;fontColor=#111827;spacing=14;" vertex="1" parent="1">
          <mxGeometry x="170" y="1120" width="1460" height="80" as="geometry"/>
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
