{
  "name": "singleton-systems",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "test": "npm run check:drift",
    "check:drift": "node scripts/check-opportunity-hq-drift.mjs",
    "check:cerebral": "node scripts/check-cerebral-drift.mjs",
    "audit:lighthouse": "node scripts/lighthouse-audit.mjs",
    "audit:seo-aeo": "node scripts/seo-aeo-live-check.mjs",
    "audit:seo-stack": "npm run audit:seo-aeo && npm run audit:lighthouse",
    "clean:generated": "node scripts/clean-generated-artifacts.mjs",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "asana:readback": "node scripts/asana-opportunity-hq-readback.mjs",
    "gas:login": "clasp -u flow login",
    "gas:create:chores": "clasp -u flow create --type standalone --title \"Personal Ops Chores\" --rootDir docs/harness/personal-ops-google-systems",
    "gas:status:chores": "clasp -u flow -P docs/harness/personal-ops-google-systems status",
    "gas:push:chores": "clasp -u flow -P docs/harness/personal-ops-google-systems push",
    "gas:pull:chores": "clasp -u flow -P docs/harness/personal-ops-google-systems pull",
    "gas:open:chores": "clasp -u flow -P docs/harness/personal-ops-google-systems open-script",
    "gas:deploy:chores": "clasp -u flow -P docs/harness/personal-ops-google-systems deploy -d \"Personal Ops Chores web feed\"",
    "gas:create:jobs": "clasp -u flow create --type standalone --title \"Job Search Prep Engine\" --rootDir docs/harness/job-search-prep-google",
    "gas:status:jobs": "clasp -u flow -P docs/harness/job-search-prep-google status",
    "gas:push:jobs": "clasp -u flow -P docs/harness/job-search-prep-google push --force",
    "gas:pull:jobs": "clasp -u flow -P docs/harness/job-search-prep-google pull",
    "gas:open:jobs": "clasp -u flow -P docs/harness/job-search-prep-google open-script",
    "gas:deploy:jobs": "clasp -u flow -P docs/harness/job-search-prep-google deploy -d \"Job Search Prep API executable\"",
    "gas:setup:jobs": "clasp -u flow -P docs/harness/job-search-prep-google run setupJobSearchPrep",
    "gas:url:jobs": "clasp -u flow -P docs/harness/job-search-prep-google run openJobSearchPrepSpreadsheet",
    "jobs:gemini-handoff": "node scripts/gemini-job-prep-handoff.mjs",
    "gws": "node scripts/google-workspace-cli.mjs",
    "gws:auth": "node scripts/google-workspace-cli.mjs auth",
    "gws:whoami": "node scripts/google-workspace-cli.mjs whoami",
    "gws:chores:setup": "node scripts/google-workspace-cli.mjs chores:setup",
    "gws:chores:repair": "node scripts/google-workspace-cli.mjs chores:repair",
    "audit:ui": "node scripts/ui-audit.mjs",
    "visuals": "npm run visual-maps:build && sh -c 'cd docs/visual-maps/dist && (sleep 1; open http://127.0.0.1:4184) & python3 -m http.server 4184 --bind 127.0.0.1'",
    "visual-maps": "likec4 start docs/visual-maps",
    "visual-maps:validate": "likec4 validate docs/visual-maps",
    "visual-maps:build": "sh -c 'rm -rf docs/visual-maps/dist public/visual-maps && likec4 build docs/visual-maps --output docs/visual-maps/dist --base /visual-maps/ && cp -R docs/visual-maps/dist public/visual-maps'",
    "visual-maps:export-portfolio": "sh -c 'rm -rf public/portfolio/likec4-light public/portfolio/likec4-dark && mkdir -p public/portfolio/likec4-light public/portfolio/likec4-dark && likec4 export png docs/visual-maps --light --flat -o public/portfolio/likec4-light -f ai_workflow_readme_map -f scouting_coordinator_bucket_map -f resume_timeline_map -f review_first_implementation_loop -t 45 --max-attempts 3 && likec4 export png docs/visual-maps --dark --flat -o public/portfolio/likec4-dark -f ai_workflow_readme_map -f scouting_coordinator_bucket_map -f resume_timeline_map -f review_first_implementation_loop -t 45 --max-attempts 3 && node scripts/generate-likec4-artifact-svgs.mjs'",
    "verify:ai-workflow-mobile": "node scripts/check-ai-workflow-mobile.mjs",
    "remotion:studio": "remotion studio remotion/index.ts",
    "remotion:scene-one:still": "remotion still remotion/index.ts ClinicalSetup1944 output/clinical-setup-1944.png --frame=110",
    "remotion:scene-one:render": "remotion render remotion/index.ts ClinicalSetup1944 output/clinical-setup-1944.mp4",
    "remotion:scene-two:assets": "node scripts/export-scene-2-remotion-assets.mjs",
    "blender:scene-two:assemble": "/Applications/Blender.app/Contents/MacOS/Blender --background --python scripts/blender_scene_2_starvation_phase.py",
    "remotion:scene-three:assets": "node scripts/export-scene-3-remotion-assets.mjs",
    "blender:scene-three:assemble": "/Applications/Blender.app/Contents/MacOS/Blender --background --python scripts/blender_scene_3_food_mania.py"
  },
  "dependencies": {
    "@calcom/embed-react": "^1.5.3",
    "@joint/core": "^4.2.5",
    "@vercel/speed-insights": "^2.0.0",
    "framer-motion": "^11.11.11",
    "geist": "^1.7.2",
    "next": "^15.5.19",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "remotion": "4.0.486",
    "satori": "^0.26.0",
    "shiki": "^4.3.1"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@google-cloud/local-auth": "^3.0.1",
    "@google/clasp": "^3.3.0",
    "@playwright/test": "^1.61.0",
    "@remotion/cli": "4.0.486",
    "@types/node": "^20.19.43",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "10.4.20",
    "eslint": "8.57.1",
    "eslint-config-next": "^15.5.19",
    "googleapis": "^173.0.0",
    "likec4": "^1.58.0",
    "pngjs": "^7.0.0",
    "postcss": "8.4.49",
    "tailwindcss": "3.4.16",
    "typescript": "5.7.2",
    "vercel": "^54.15.1",
    "zod": "4.3.6"
  }
}
